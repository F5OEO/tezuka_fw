 	drvdata->cdev.owner = THIS_MODULE;
-	minor = ida_simple_get(&maia_sdr_device_ida, 0, MAIA_SDR_MINOR_MAX,
+	minor = ida_alloc_range(&maia_sdr_device_ida, 0, MAIA_SDR_MINOR_MAX - 1,
 			       GFP_KERNEL);
 	if (minor < 0) {
 		ret = minor;
@@ -350,7 +350,7 @@
