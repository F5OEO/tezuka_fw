--- a/cmd/Kconfig
+++ b/cmd/Kconfig
@@ -2690,6 +2690,17 @@ config CMD_SELECT_FONT
 	  Enabling this will provide 'font' command.
 	  Allows font selection at runtime.
 
+config CMD_ADI_HWREF
+	bool "adi_hwref - Analog Devices HW revision and boot mode detection"
+	depends on ARCH_ZYNQ || ARCH_ZYNQMP
+	default n
+	help
+	  Enable the adi_hwref command used on Analog Devices PlutoSDR
+	  and ADALM2000 (M2k) boards. It reads the Zynq on-chip XADC to
+	  sample a resistor-divider voltage unique to each board revision,
+	  then sets the U-Boot env variable fit_config to the matching
+	  FIT configuration entry (config@0 .. config@9). Also reads the
+	  Zynq SLCR BOOT_MODE register to set modeboot if unset.
 endmenu
 
 source "cmd/ti/Kconfig"
diff --git a/cmd/Makefile b/cmd/Makefile
index bbbdfcc4..8ed4cf58 100644
--- a/cmd/Makefile
+++ b/cmd/Makefile
@@ -18,6 +18,7 @@ obj-$(CONFIG_CMD_ACPI) += acpi.o
 obj-$(CONFIG_CMD_ADDRMAP) += addrmap.o
 obj-$(CONFIG_CMD_AES) += aes.o
 obj-$(CONFIG_CMD_ADC) += adc.o
+obj-$(CONFIG_CMD_ADI_HWREF) += adi_hwref.o
 obj-$(CONFIG_CMD_ARMFLASH) += armflash.o
 obj-$(CONFIG_BLK) += blk_common.o
