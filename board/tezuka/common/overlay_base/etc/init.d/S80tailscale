#!/bin/sh
# Tailscale VPN daemon
# State persisted on jffs2 across reboots.
# First-time setup: run 'tailscale up' on serial console or local SSH.

STATEDIR="/mnt/jffs2/tailscale"
SOCKET="/var/run/tailscale/tailscaled.sock"

start() {
    [ -x /usr/sbin/tailscaled ] || return 0
    printf "Starting tailscaled: "
    mkdir -p /var/run/tailscale "$STATEDIR"
    start-stop-daemon -S -b -x /usr/sbin/tailscaled -- \
        --state="$STATEDIR/tailscaled.state" \
        --socket="$SOCKET"
    echo "OK"
}

stop() {
    [ -x /usr/sbin/tailscaled ] || return 0
    printf "Stopping tailscaled: "
    start-stop-daemon -K -x /usr/sbin/tailscaled 2>/dev/null
    echo "OK"
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; start ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac
