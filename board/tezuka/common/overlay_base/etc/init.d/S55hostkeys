#!/bin/sh

case "$1" in
	start|"")
		printf "Starting host keys backup: "
		# Save OpenSSH host keys to jffs2
		mkdir -p /mnt/jffs2/etc/ssh
		for key in /etc/ssh/ssh_host_*; do
			[ -f "$key" ] && cp "$key" /mnt/jffs2/etc/ssh/
		done
		# Save authorized keys
		[ -f /root/.ssh/authorized_keys ] && cp /root/.ssh/authorized_keys /mnt/jffs2/etc/ssh/authorized_keys
		echo "OK"
		;;
	stop)
		;;
	*)
		echo "Usage: $0 {start|stop}" >&2
		exit 1
		;;
esac
