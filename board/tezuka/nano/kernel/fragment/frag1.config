CONFIG_DEBUG_ZYNQ_UART1=y
CONFIG_CMA_SIZE_MBYTES=32

# Memory corruption detection — page allocator crash forensics
# Catches use-after-free / buffer overflow in SLUB allocator at first fault
# with exact backtrace, not delayed Oops hours later
CONFIG_SLUB_DEBUG=y
CONFIG_SLUB_DEBUG_ON=y
CONFIG_SLUB_STATS=y

# Enable kernel debug infrastructure required by DEBUG_LIST and DEBUG_SG
CONFIG_DEBUG_KERNEL=y

# Validate linked list operations (page allocator uses list_head heavily)
CONFIG_DEBUG_LIST=y

# Validate DMA scatter-gather lists
CONFIG_DEBUG_SG=y

# Reboot cleanly on kernel Oops — page allocator corruption is unrecoverable
CONFIG_PANIC_ON_OOPS=y
CONFIG_PANIC_TIMEOUT=10

